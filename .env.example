# ---------------------------------------------------------------------------
# Database (PostgreSQL — Supabase or Neon)
# ---------------------------------------------------------------------------
# Supabase: Project Settings → Database → Connection string (use the pooled
# "Transaction" URL for the app, and the direct URL for migrations if needed).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# ---------------------------------------------------------------------------
# Better Auth
# ---------------------------------------------------------------------------
# Generate a strong secret, e.g.:  openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-string"
# Base URL of the app (no trailing slash). Use the deployed URL in production.
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Email (Gmail SMTP)
# ---------------------------------------------------------------------------
# The Gmail address that sends mail, and a Google App Password (NOT your normal
# password). Create one at: https://myaccount.google.com/apppasswords
GMAIL_USER="youraddress@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"
# Optional friendly From header; defaults to GMAIL_USER if unset.
EMAIL_FROM="University Notice Board <youraddress@gmail.com>"

# ---------------------------------------------------------------------------
# App configuration
# ---------------------------------------------------------------------------
# Comma-separated university email domains allowed to register.
ALLOWED_EMAIL_DOMAINS="university.edu"
