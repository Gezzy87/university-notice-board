# ---------------------------------------------------------------------------
# Database (PostgreSQL — Supabase)
# ---------------------------------------------------------------------------
# Supabase → Connect → ORM/Prisma. Two URLs are needed:
#   DATABASE_URL = Transaction pooler (port 6543) — used by the app at runtime.
#   DIRECT_URL   = Direct/Session connection (port 5432) — used by migrations.
# Add ?pgbouncer=true to the pooled URL so Prisma plays nicely with the pooler.
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Better Auth
# ---------------------------------------------------------------------------
# Generate a strong secret, e.g.:  openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-string"
# Base URL of the app (no trailing slash). Use the deployed URL in production.
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Email (Gmail SMTP)
# ---------------------------------------------------------------------------
# The Gmail address that sends mail, and a Google App Password (NOT your normal
# password). Create one at: https://myaccount.google.com/apppasswords
GMAIL_USER="youraddress@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"
# Optional friendly From header; defaults to GMAIL_USER if unset.
EMAIL_FROM="University Notice Board <youraddress@gmail.com>"

# ---------------------------------------------------------------------------
# App configuration
# ---------------------------------------------------------------------------
# Comma-separated university email domains allowed to register (enforced
# server-side at sign-up). Leave empty to allow any domain.
ALLOWED_EMAIL_DOMAINS="university.edu"

# ---------------------------------------------------------------------------
# Supabase Storage (image uploads) — server-side only, never NEXT_PUBLIC
# ---------------------------------------------------------------------------
# Supabase → Project Settings → API:
#   SUPABASE_URL              = Project URL (https://<ref>.supabase.co)
#   SUPABASE_SERVICE_ROLE_KEY = the secret service_role key
# Run `npm run storage:setup` once to create the public bucket.
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"
SUPABASE_STORAGE_BUCKET="images"

# ---------------------------------------------------------------------------
# Admin bootstrap (used by `npm run admin:create`)
# ---------------------------------------------------------------------------
# In production, ADMIN_PASSWORD is REQUIRED (the script refuses the weak default).
ADMIN_EMAIL="admin@university.edu"
ADMIN_PASSWORD="change-me-to-a-strong-password"
ADMIN_NAME="Admin User"
